<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <title><%= yield(:title).presence || "Errbot" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Errbot">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-full bg-zinc-100 text-zinc-950 antialiased dark:bg-zinc-950 dark:text-zinc-50">
    <!-- App shell background and global page chrome -->
    <div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(255,51,0,0.12),_transparent_32%),linear-gradient(to_bottom,_rgba(255,255,255,0.98),_rgba(244,244,245,0.96))] dark:bg-[radial-gradient(circle_at_top,_rgba(255,80,32,0.14),_transparent_26%),linear-gradient(to_bottom,_rgba(24,24,27,0.98),_rgba(9,9,11,0.98))]">
      <!-- Primary app header with brand, navigation, and current-user controls -->
      <header class="border-b border-zinc-200/70 bg-white/80 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/80">
        <div class="mx-auto flex w-full max-w-7xl items-center justify-between gap-6 px-6 py-4">
          <div class="flex items-center gap-6">
            <!-- Brand / home link -->
            <%= link_to root_path, class: "flex items-center gap-3 text-sm font-semibold tracking-[0.22em] text-zinc-950 uppercase dark:text-zinc-50" do %>
              <span class="inline-flex h-3 w-3 rounded-full bg-[#FF3300] shadow-[0_0_20px_rgba(255,51,0,0.45)]"></span>
              Errbot
            <% end %>
            <!-- Primary navigation -->
            <nav class="flex flex-wrap items-center gap-2 text-sm">
              <%= link_to "Issues", root_path, class: "rounded-full px-3 py-2 text-zinc-600 transition hover:bg-zinc-950 hover:text-white dark:text-zinc-300 dark:hover:bg-white dark:hover:text-zinc-950" %>
              <% if Current.user&.admin? %>
                <%= link_to "Authorized Users", authorized_users_path, class: "rounded-full px-3 py-2 text-zinc-600 transition hover:bg-zinc-950 hover:text-white dark:text-zinc-300 dark:hover:bg-white dark:hover:text-zinc-950" %>
                <%= link_to "Projects", projects_path, class: "rounded-full px-3 py-2 text-zinc-600 transition hover:bg-zinc-950 hover:text-white dark:text-zinc-300 dark:hover:bg-white dark:hover:text-zinc-950" %>
              <% end %>
            </nav>
          </div>
          <% if Current.user.present? %>
            <!-- Current user summary and logout action -->
            <div class="flex items-center gap-3">
              <div class="hidden text-right sm:block">
                <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100"><%= Current.user.name.presence || Current.user.email_address %></p>
                <p class="text-xs uppercase tracking-[0.2em] text-zinc-500 dark:text-zinc-400"><%= Current.user.admin? ? "Administrator" : "Authorized user" %></p>
              </div>
              <%= button_to "Logout", logout_path, method: :delete, class: "cursor-pointer rounded-full border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 transition hover:border-zinc-950 hover:text-zinc-950 dark:border-zinc-700 dark:text-zinc-200 dark:hover:border-zinc-100 dark:hover:text-zinc-50" %>
            </div>
          <% end %>
        </div>
      </header>

      <!-- Page content container -->
      <main class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-6 py-8">
        <!-- Global flash messages -->
        <% flash.each do |type, message| %>
          <%= render FlashMessage::Component.new(type: type, message: message) %>
        <% end %>
        <!-- Route-specific page content -->
        <%= yield %>
      </main>
    </div>
  </body>
</html>
