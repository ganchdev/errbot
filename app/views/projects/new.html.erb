<% content_for :title, "New Project" %>

<section class="max-w-2xl rounded-[2rem] border border-zinc-200/70 bg-white/90 p-6 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
  <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#FF3300]">Admin</p>
  <h1 class="mt-2 text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">New project</h1>
  <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Create a project with its name, slug, and default environment.</p>
  <div class="mt-6">
    <%= render "form", project: @project, submit_label: "Create project" %>
  </div>
</section>
