<% content_for :title, "Verify Telegram Account" %>

<!-- Telegram verification page -->
<section class="mx-auto max-w-3xl space-y-6">
  <!-- Verification hero / status card -->
  <article class="rounded-[2rem] border border-zinc-200/70 bg-white/90 p-8 shadow-sm dark:border-zinc-800 dark:bg-zinc-900/80">
    <% if @error %>
      <!-- Error state -->
      <div class="space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#FF3300]">Telegram verification</p>
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Verification unavailable</h1>
        <div class="rounded-2xl border border-red-500/30 bg-red-500/10 px-4 py-4 text-sm font-medium text-red-900 dark:text-red-100">
          <%= @error %>
        </div>
        <p class="text-sm leading-6 text-zinc-600 dark:text-zinc-400">
          Please return to Telegram, restart the linking flow, and make sure you are signed in with the same Google account as the authorized email address.
        </p>
        <p class="text-sm leading-6 text-zinc-600 dark:text-zinc-400">
          If the problem continues, please contact the administrator.
        </p>
      </div>
    <% else %>
      <!-- Success state -->
      <div class="space-y-4">
        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-[#FF3300]">Telegram verification</p>
        <h1 class="text-3xl font-semibold tracking-tight text-zinc-950 dark:text-zinc-50">Verify Telegram Account</h1>
        <p class="text-sm leading-6 text-zinc-600 dark:text-zinc-400">
          Enter this code in your Telegram chat to link your account. The code is short-lived and tied to your current verification request.
        </p>
      </div>

      <!-- Verification code block -->
      <div class="mt-8 rounded-[2rem] border border-zinc-200/70 bg-zinc-50/80 p-6 dark:border-zinc-800 dark:bg-zinc-950/70">
        <p class="text-xs uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400">Verification code</p>
        <div class="mt-4">
          <%= render CopyButton::Component.new(label: "Copy code") do %>
            <%= @code %>
          <% end %>
        </div>
        <p class="mt-4 text-sm text-zinc-600 dark:text-zinc-400">This code expires in 10 minutes.</p>
      </div>
    <% end %>
  </article>
</section>
