<% if normalized_frames.any? %>
  <div class="space-y-3">
    <% normalized_frames.each_with_index do |frame, index| %>
      <details class="group overflow-hidden rounded-2xl border border-zinc-200/70 bg-zinc-50/80 transition open:bg-white dark:border-zinc-800 dark:bg-zinc-950/40 dark:open:bg-zinc-950/70" <%= "open" if index.zero? %>>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold text-zinc-900 marker:hidden dark:text-zinc-50">
          <span class="font-mono text-xs leading-6 sm:text-sm"><%= frame_title(frame) %></span>
          <span class="text-xs uppercase tracking-[0.22em] text-zinc-500 transition group-open:rotate-90 dark:text-zinc-400">></span>
        </summary>

        <div>
          <div class="overflow-x-auto rounded-2xl bg-zinc-950 ring-1 ring-zinc-900/80">
            <ol class="m-0 min-w-full list-none p-0 font-mono text-xs leading-6 text-zinc-100">
              <% frame_source_lines(frame).each do |line| %>
                <li class="<%= source_line_row_classes(line) %>">
                  <span class="<%= source_line_number_classes(line) %>"><%= line[:number] || " " %></span>
                  <code class="<%= source_line_code_classes(line) %>"><%= line[:content].presence || " " %></code>
                </li>
              <% end %>
            </ol>
          </div>
        </div>
      </details>
    <% end %>
  </div>
<% else %>
  <p class="text-sm text-zinc-500 dark:text-zinc-400">The latest event was stored without stack frames.</p>
<% end %>
